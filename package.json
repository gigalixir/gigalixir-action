{
  "name": "gigalixir-action",
  "version": "1.0.0",
  "description": "GitHub Action for deploying applications to Gigalixir",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "format": "prettier --write '**/*.ts'",
    "format:check": "prettier --check '**/*.ts'",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "all": "npm run format && npm run lint && npm run test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gigalixir/gigalixir-action.git"
  },
  "keywords": [
    "gigalixir",
    "deploy",
    "elixir",
    "phoenix",
    "github-action"
  ],
  "author": "Gigalixir",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gigalixir/gigalixir-action/issues"
  },
  "homepage": "https://github.com/gigalixir/gigalixir-action#readme",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.57.0",
    "eslint-plugin-github": "^4.10.2",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
